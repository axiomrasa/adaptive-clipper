#N canvas 200 200 600 500 12;
#X obj 50 60 adc~ 1 2;
#X obj 50 400 dac~ 1 2;
#X obj 50 10 r Drive @hv_param 1.0 5.0 1.0;
#X obj 200 10 r Punch @hv_param 0.0 1.0 0.0;
#X obj 50 35 sig~;
#X obj 200 35 sig~;
#X obj 50 90 *~;
#X obj 90 90 *~;
#X obj 200 90 +~;
#X obj 200 120 abs~;
#X obj 200 150 lop~ 40;
#X obj 250 150 lop~ 5;
#X obj 200 180 -~;
#X obj 200 210 clip~ 0 100;
#X obj 200 240 *~ 8;
#X obj 200 270 *~;
#X obj 200 300 +~ 2;
#X obj 50 350 expr~ $v1 / pow(1 + pow(abs($v1)+0.000001 \, $v2) \, 1/$v2);
#X obj 150 350 expr~ $v1 / pow(1 + pow(abs($v1)+0.000001 \, $v2) \, 1/$v2);
#X connect 0 0 6 0;
#X connect 0 1 7 0;
#X connect 2 0 4 0;
#X connect 3 0 5 0;
