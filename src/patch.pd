name: Cross-Platform PlugData Toolchain Compiler

on:
  push:
    branches: [ main, master ]

jobs:
  compile-plugins:
    name: Build Native Audio Plugins
    runs-on: ${{ matrix.os }}
    strategy:
      fail-fast: false
      matrix:
        include:
          - os: macos-14
            platform: macos
            artifact-path: src/build/AdaptiveClipper.vst3
          - os: windows-latest
            platform: windows
            artifact-path: src/build/AdaptiveClipper.vst3
          - os: ubuntu-latest
            platform: linux
            artifact-path: src/build/AdaptiveClipper.vst3

    steps:
      - name: Checkout Source Code
        uses: actions/checkout@v4
        with:
          submodules: recursive

      - name: Setup Python Environment
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install Heavy Compiler Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install hvcc

      - name: Run Toolchain Binary Compilation
        run: |
          # Executes the structural transformation from visual patch to multi-target native bundles
          hvcc src/patch.pd -o src/build -p cplusplus -g framework-juce

      - name: Upload Production Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: AdaptiveClipper-${{ matrix.platform }}
          path: ${{ matrix.artifact-path }}