#N canvas 200 200 700 600 12;
#X obj 50 50 adc~ 1 2;
#X obj 50 500 dac~ 1 2;
#X obj 50 10 r Drive @hv_param 1.0 5.0 1.0;
#X obj 300 10 r Punch @hv_param 0.0 1.0 0.0;
#X obj 50 40 pack f 20;
#X obj 50 70 line~;
#X obj 300 40 pack f 20;
#X obj 300 70 line~;
#X obj 100 120 *~;
#X obj 150 120 *~;
#X obj 200 150 +~;
#X obj 200 180 abs~;
#X obj 200 210 lop~ 40;
#X obj 250 210 lop~ 5;
#X obj 200 240 -~;
#X obj 200 270 clip~ 0 100;
#X obj 200 300 *~ 8;
#X obj 200 330 *~;
#X obj 200 360 +~ 2;
#X obj 100 420 expr~ $v1 / pow(1 + pow(abs($v1)+0.000001 \, $v2) \, 1/$v2);
#X obj 150 420 expr~ $v1 / pow(1 + pow(abs($v1)+0.000001 \, $v2) \, 1/$v2);
